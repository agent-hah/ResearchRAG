    "@tiptap/starter-kit": "^3.26.1",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-draggable": "^4.6.0",
    "react-hook-form": "^7.77.0",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tiptap-markdown": "^0.9.0"
